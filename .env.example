# SaveMyGrade environment template
# Copy this file to .env and fill in real values.

# Required for Gemini / Google AI usage in backend services.
GOOGLE_API_KEY=your_google_ai_api_key_here

# Flask server config
FLASK_HOST=0.0.0.0
FLASK_PORT=5050
FLASK_DEBUG=true

# Optional: recommendation/data settings
RMP_SCHOOL_NAME=Simon Fraser University
RMP_MAX_RESULTS=10
